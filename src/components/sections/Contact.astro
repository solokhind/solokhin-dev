---
import { ArrowUpRight } from "@lucide/astro";
---

<section id="contact">
  <h2 class="section-title">Contact</h2>

  <div class="prose-body">
    <p>Want to get in touch? Send me an email.</p>
  </div>

  <div class="mt-6 flex flex-col gap-3">
    <a
      href="mailto:dmitriy@solokhin.dev"
      class="font-inter font-light text-sm text-foreground underline underline-offset-2 decoration-border hover:decoration-foreground/50 transition-[text-decoration-color] duration-150 w-fit"
    >
      dmitriy@solokhin.dev
    </a>
    <a
      href="https://assets.solokhin.dev/resume.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="font-inter font-light text-sm text-muted-foreground hover:text-foreground transition-colors duration-150 w-fit flex items-center gap-1.5"
    >
      <span>Download resume</span>
      <ArrowUpRight class="size-3.5" stroke-width={1.7} />
    </a>
  </div>
</section>
