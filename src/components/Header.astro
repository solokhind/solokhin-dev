---
import { Sun, Moon, Monitor } from "@lucide/astro";
---

<header
  class="flex justify-center
    w-full px-6
    bg-background
    sm:sticky sm:top-0 sm:z-50"
>
  <div class="flex flex-col
      w-full max-w-180
      pt-4 pb-2.5">
    <div class="flex items-baseline justify-between
        pb-2 gap-4">
      <a
        href="/"
        class="font-normal
          text-base tracking-wider leading-none
          text-foreground no-underline
          shrink-0
          transition-opacity duration-150
          hover:opacity-50"
        >Dmitriy Solokhin</a
      >
      <span
        class="font-inter font-extralight
          text-xs tracking-wider
          text-foreground/40 whitespace-nowrap
          max-[580px]:hidden"
        >Full-Stack Software Engineer</span
      >
    </div>
    <div class="h-px w-full bg-foreground/15"></div>
    <div class="flex items-center justify-between
        pt-2">
      <nav
        class="flex items-center gap-6 max-[580px]:gap-3.5"
        aria-label="Main navigation"
      >
        {
          ["About", "Experience", "Skills", "Personal", "Contact"].map(
            (item) => (
              <a
                href={`#${item.toLowerCase()}`}
                class="
                  font-inter font-light
                  text-xs tracking-wide
                  text-foreground/50 no-underline whitespace-nowrap
                  transition-colors duration-150
                  hover:text-foreground
                "
              >
                {item}
              </a>
            ),
          )
        }
      </nav>
      <button
        type="button"
        class="flex items-center
          p-0.5 shrink-0
          bg-transparent border-0 cursor-pointer
          text-foreground/35
          transition-colors duration-150
          hover:text-foreground"
        id="theme-toggle"
        aria-label="Toggle theme"
      >
        <Sun id="icon-light" class="hidden size-3.25" stroke-width={2} />
        <Moon id="icon-dark" class="hidden size-3.25" stroke-width={2} />
        <Monitor id="icon-system" class="size-3.25" stroke-width={2} />
      </button>
    </div>
  </div>
</header>
